PORT="8000"
MONGO_URI="your_mongo_db_connection_string_here"

NODE_ENV="development"

JWT_SECRET="your_super_secret_key_12345"
JWT_EXPIRE="7d"

ADMIN_NAME="SuperAdmin"
ADMIN_EMAIL="sagarsharma3013@gmail.com"
ADMIN_PASSWORD="sagarsharma3013@gmail.com"

FRONTEND_URL="http://localhost:3000"

# Redis / BullMQ
# Required for abandoned cart scheduling and reminder jobs
# Local Redis container started with:
# docker run -d -p 6379:6379 --name redis redis
REDIS_URL="redis://localhost:6379"
# If the app itself runs inside Docker, use the Redis container name instead:
# REDIS_URL="redis://redis:6379"
# If you prefer host/port settings instead of REDIS_URL, use these:
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_DB="0"
ABANDONED_CART_INACTIVITY_MINUTES="1"
ABANDONED_CART_FIRST_REMINDER_MINUTES="1"

# Firebase Admin SDK
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_CLIENT_ID=""
FIREBASE_AUTH_URI="https://accounts.google.com/o/oauth2/auth"
FIREBASE_TOKEN_URI="https://oauth2.googleapis.com/token"
FIREBASE_AUTH_PROVIDER_X509_CERT_URL="https://www.googleapis.com/oauth2/v1/certs"
FIREBASE_CLIENT_X509_CERT_URL=""

# Node Mailer
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SERVICE="gmail"
SMTP_MAIL="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"

RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
